# ── Fly.io ────────────────────────────────────────────────────────────
# Required: Fly.io API token for deployments (used in CI)
FLY_API_TOKEN=your-fly-api-token

# App and region are baked into fly.toml and deploy scripts.
# Override here if needed for scripting:
# APP_NAME=your-app-name
# REGION=iad
