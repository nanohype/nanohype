# ── Vercel ─────────────────────────────────────────────────────────────
# Required: Vercel token for CLI and CI deploys
VERCEL_TOKEN=your-vercel-token

# Required for CI: Vercel org and project IDs (from .vercel/project.json)
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# App-specific environment variables can be set via:
#   vercel env add VARIABLE_NAME
# or in the Vercel dashboard under Project Settings > Environment Variables.
