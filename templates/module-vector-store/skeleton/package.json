{
  "name": "__PROJECT_NAME__",
  "version": "0.1.0",
  "description": "__DESCRIPTION__",
  "type": "module",
  "main": "dist/vector-store/index.js",
  "types": "dist/vector-store/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/vector-store/index.d.ts",
      "import": "./dist/vector-store/index.js"
    },
    "./providers": {
      "types": "./dist/vector-store/providers/index.d.ts",
      "import": "./dist/vector-store/providers/index.js"
    },
    "./filters": {
      "types": "./dist/vector-store/filters/types.d.ts",
      "import": "./dist/vector-store/filters/types.js"
    },
    "./similarity": {
      "types": "./dist/vector-store/similarity.d.ts",
      "import": "./dist/vector-store/similarity.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:prod": "npm audit --audit-level=high --omit=dev"
  },
  "dependencies": {
    "@pinecone-database/pinecone": "^4.0.0",
    "pg": "^8.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "prettier": "^3.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=24"
  }
}
