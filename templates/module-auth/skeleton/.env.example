# ── Auth Module ───────────────────────────────────────────────────────
# Provider-specific variables. Enable the ones matching your auth provider.

# ── JWT Provider ─────────────────────────────────────────────────────
# Required if using JWT: Signing secret or JWKS endpoint
# AUTH_JWT_SECRET=your-jwt-secret
# AUTH_JWT_JWKS_URL=https://your-issuer/.well-known/jwks.json
# AUTH_JWT_ISSUER=https://your-issuer
# AUTH_JWT_AUDIENCE=your-audience

# ── API Key Provider ─────────────────────────────────────────────────
# Required if using API key auth: Comma-separated list of valid keys
# AUTH_API_KEYS=key1,key2,key3

# ── Auth0 Provider ───────────────────────────────────────────────────
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_AUDIENCE=https://your-api

# ── Supabase Provider ────────────────────────────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Clerk Provider ───────────────────────────────────────────────────
# CLERK_SECRET_KEY=sk_your-clerk-secret-key
