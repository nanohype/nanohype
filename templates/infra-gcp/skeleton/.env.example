# ── Google Cloud ──────────────────────────────────────────────────────
# Required: GCP project ID
GCP_PROJECT=your-gcp-project-id

# Required: GCP region for Cloud Run and Cloud SQL
GCP_REGION=us-central1

# CI/CD: Workload Identity Federation (used in GitHub Actions)
# WIF_PROVIDER=projects/123456/locations/global/workloadIdentityPools/github/providers/github
# WIF_SERVICE_ACCOUNT=deployer@your-project.iam.gserviceaccount.com
