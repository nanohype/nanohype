{
  "displayName": "__PROJECT_NAME__ High Error Rate",
  "documentation": {
    "content": "Cloud Run service __PROJECT_NAME__ is returning elevated 5xx error rates. Check service logs and recent deployments.",
    "mimeType": "text/markdown"
  },
  "conditions": [
    {
      "displayName": "5xx error rate > 5%",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"__PROJECT_NAME__\" AND metric.type=\"run.googleapis.com/request_count\" AND metric.labels.response_code_class=\"5xx\"",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_RATE"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0.05,
        "duration": "300s",
        "trigger": {
          "count": 1
        }
      }
    }
  ],
  "combiner": "OR",
  "enabled": true
}
