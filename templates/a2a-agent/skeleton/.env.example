# ── AI Provider ───────────────────────────────────────────────────────
# At least one provider key is required. The Anthropic and OpenAI SDKs
# read these automatically when constructing their clients.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
OPENAI_API_KEY=sk-your-openai-api-key

# ── Agent ────────────────────────────────────────────────────────────
# Public URL for this agent's A2A discovery card
AGENT_URL=http://localhost:3000

# ── Application ──────────────────────────────────────────────────────
# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info
