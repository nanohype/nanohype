{
  "name": "__PROJECT_NAME__",
  "version": "0.1.0",
  "description": "__DESCRIPTION__",
  "type": "module",
  "main": "dist/semantic-cache/index.js",
  "types": "dist/semantic-cache/index.d.ts",
  "exports": {
    ".": "./dist/semantic-cache/index.js",
    "./embedder": "./dist/semantic-cache/embedder/index.js",
    "./store": "./dist/semantic-cache/store/index.js",
    "./similarity": "./dist/semantic-cache/similarity.js",
    "./gateway-adapter": "./dist/semantic-cache/gateway-adapter.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx --watch src/semantic-cache/index.ts",
    "start": "node dist/semantic-cache/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:prod": "npm audit --audit-level=high --omit=dev"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1030.0",
    "@opentelemetry/api": "^1.9.1",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4"
  },
  "engines": {
    "node": ">=24"
  }
}
