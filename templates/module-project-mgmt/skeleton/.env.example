# ── Project Management Module ──────────────────────────────────────────
# API keys for each provider. Only set the ones you use.

# ── Linear ─────────────────────────────────────────────────────────
# LINEAR_API_KEY=lin_api_...

# ── Jira ───────────────────────────────────────────────────────────
# JIRA_EMAIL=you@example.com
# JIRA_TOKEN=...
# JIRA_BASE_URL=https://your-org.atlassian.net

# ── Asana ──────────────────────────────────────────────────────────
# ASANA_TOKEN=1/...

# ── Shortcut ───────────────────────────────────────────────────────
# SHORTCUT_TOKEN=...
