# ── Worker ────────────────────────────────────────────────────────────
HEALTH_PORT=9090
LOG_LEVEL=info

# ── Queue ────────────────────────────────────────────────────────────
QUEUE_PROVIDER=__QUEUE_PROVIDER__
QUEUE_POLL_INTERVAL=1000
QUEUE_CONCURRENCY=5

# ── Cron ─────────────────────────────────────────────────────────────
CRON_ENABLED=true

# ── Shutdown ─────────────────────────────────────────────────────────
SHUTDOWN_TIMEOUT=30000

# ── OpenTelemetry ────────────────────────────────────────────────────
OTEL_SERVICE_NAME=__PROJECT_NAME__
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
