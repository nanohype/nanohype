# ── Server ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────
# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/__PROJECT_NAME__

# SQLite (alternative)
# DATABASE_URL=sqlite://data/__PROJECT_NAME__.db

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ISSUER=__PROJECT_NAME__

# ── OpenTelemetry ─────────────────────────────────────────────────────
OTEL_SERVICE_NAME=__PROJECT_NAME__
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
