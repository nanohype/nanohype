# ── Cache Module ──────────────────────────────────────────────────────
# Provider-specific variables. Enable the ones matching your cache backend.

# ── Redis ────────────────────────────────────────────────────────────
# Option A: Full connection URL
# REDIS_URL=redis://localhost:6379

# Option B: Host/port separately
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# ── Memcached ────────────────────────────────────────────────────────
# Comma-separated server list
# MEMCACHED_SERVERS=localhost:11211
