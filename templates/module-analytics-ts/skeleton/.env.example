# ── Analytics Module ───────────────────────────────────────────────
# API keys for each provider. Only set the ones you use.

# ── Segment ────────────────────────────────────────────────────────
# SEGMENT_WRITE_KEY=...

# ── PostHog ────────────────────────────────────────────────────────
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://us.i.posthog.com

# ── Mixpanel ───────────────────────────────────────────────────────
# MIXPANEL_TOKEN=...

# ── Amplitude ──────────────────────────────────────────────────────
# AMPLITUDE_API_KEY=...
