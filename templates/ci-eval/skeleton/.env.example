# ── AI Provider ───────────────────────────────────────────────────────
# At least one provider key is required. The Anthropic and OpenAI SDKs
# read these automatically when constructing their clients.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
OPENAI_API_KEY=sk-your-openai-api-key

# ── Eval Config ──────────────────────────────────────────────────────
# Directory containing YAML eval suite files
EVAL_PATH=__EVAL_PATH__
# Maximum allowed score regression (0.0–1.0)
REGRESSION_THRESHOLD=__REGRESSION_THRESHOLD__
# Default LLM provider (anthropic, openai)
LLM_PROVIDER=__LLM_PROVIDER__
# Path to baseline JSON file
BASELINE_PATH=.eval-baseline.json

# ── Application ──────────────────────────────────────────────────────
# Log level (debug, info, warn, error)
LOG_LEVEL=info
