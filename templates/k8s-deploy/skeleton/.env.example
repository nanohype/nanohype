# ── Kubernetes Deployment ─────────────────────────────────────────────
# CI/CD: Container registry and image name (used in GitHub Actions)
# IMAGE_REGISTRY=ghcr.io
# IMAGE_NAME=your-org/your-app

# CI/CD: Base64-encoded kubeconfig for deployment (stored as GitHub secret)
# KUBECONFIG=base64-encoded-kubeconfig
