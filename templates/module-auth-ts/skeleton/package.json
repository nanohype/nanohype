{
  "name": "__PROJECT_NAME__",
  "version": "0.1.0",
  "description": "__DESCRIPTION__",
  "type": "module",
  "main": "dist/auth/index.js",
  "types": "dist/auth/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./providers": {
      "types": "./dist/auth/providers/index.d.ts",
      "import": "./dist/auth/providers/index.js"
    },
    "./guards": {
      "types": "./dist/auth/guards.d.ts",
      "import": "./dist/auth/guards.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jose": "^6.0.0",
    "@clerk/backend": "^1.0.0",
    "auth0": "^4.0.0",
    "@supabase/supabase-js": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
