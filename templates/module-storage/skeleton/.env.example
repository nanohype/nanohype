# ── AWS S3 ───────────────────────────────────────────────────────────
# Credentials resolved via the default AWS credential chain
# (environment variables, shared config, IAM role, etc.)

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Cloudflare R2 ───────────────────────────────────────────────────
# R2 uses S3-compatible credentials with a Cloudflare account ID

# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# ── Google Cloud Storage ─────────────────────────────────────────────
# Credentials resolved via Application Default Credentials (ADC)

# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT_ID=

# ── Local Filesystem ────────────────────────────────────────────────

# Base directory for the local storage provider (defaults to .storage)
# LOCAL_STORAGE_PATH=.storage
