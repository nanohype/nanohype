# ── Media Module ───────────────────────────────────────────────────
# API keys for each provider. Only set the ones you use.

# ── Cloudinary ────────────────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...

# ── Uploadcare ────────────────────────────────────────────────────
# UPLOADCARE_PUBLIC_KEY=...
# UPLOADCARE_SECRET_KEY=...

# ── imgix ─────────────────────────────────────────────────────────
# IMGIX_SOURCE=...
# IMGIX_TOKEN=...
