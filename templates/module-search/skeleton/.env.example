# ── Search Module ──────────────────────────────────────────────────
# API keys for each provider. Only set the ones you use.

# ── Algolia ────────────────────────────────────────────────────────
# ALGOLIA_APP_ID=...
# ALGOLIA_API_KEY=...

# ── Typesense ──────────────────────────────────────────────────────
# TYPESENSE_URL=http://localhost:8108
# TYPESENSE_API_KEY=...

# ── Meilisearch ────────────────────────────────────────────────────
# MEILISEARCH_URL=http://localhost:7700
# MEILISEARCH_MASTER_KEY=...
