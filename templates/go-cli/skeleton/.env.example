# ── Go CLI ────────────────────────────────────────────────────────────
# Viper reads these with the project-specific prefix (e.g. MYAPP_LOG_FORMAT).
# They can also be set in ~/.__PROJECT_NAME__.yaml or ./__PROJECT_NAME__.yaml.

# Optional: Log output format (json, text)
LOG_FORMAT=text

# Optional: Enable verbose output
VERBOSE=false
