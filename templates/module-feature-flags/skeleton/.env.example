# ── Flag Store ────────────────────────────────────────────────────────
# Redis connection (only needed when using the redis flag store)
REDIS_URL=redis://127.0.0.1:6379

# JSON file path (only needed when using the json-file flag store)
FLAGS_FILE_PATH=./flags.json

# ── Application ──────────────────────────────────────────────────────
# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info
