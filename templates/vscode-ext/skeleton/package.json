{
  "name": "__PROJECT_NAME__",
  "displayName": "__EXTENSION_NAME__",
  "description": "__DESCRIPTION__",
  "version": "0.1.0",
  "publisher": "__PUBLISHER__",
  "engines": {
    "vscode": "^1.96.0",
    "node": ">=22"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "__ACTIVATION_EVENT__"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "__PROJECT_NAME__.example",
        "title": "__EXTENSION_NAME__: Run Example Command"
      },
      {
        "command": "__PROJECT_NAME__.openWebview",
        "title": "__EXTENSION_NAME__: Open Webview Panel"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "openai": "^4.85.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.1.0"
  }
