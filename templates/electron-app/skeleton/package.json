{
  "name": "__PROJECT_NAME__",
  "version": "0.1.0",
  "private": true,
  "description": "__DESCRIPTION__",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "node esbuild.config.mjs --watch",
    "dev:renderer": "vite",
    "build": "node esbuild.config.mjs && vite build",
    "start": "electron dist/main/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "openai": "^4.85.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.0.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
