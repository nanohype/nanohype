# ── AI Provider Keys ──────────────────────────────────────────────────
# Set the API key for your chosen provider. Keys are stored in the
# main process only — the renderer never sees them.

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI
# OPENAI_API_KEY=your-openai-api-key

# Default provider (anthropic or openai)
LLM_PROVIDER=__LLM_PROVIDER__
