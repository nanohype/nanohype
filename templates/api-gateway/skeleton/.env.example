# ── Server ───────────────────────────────────────────────────────────

# Port to listen on (default: 8080)
PORT=8080

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ── Authentication ───────────────────────────────────────────────────

# Symmetric secret for JWT verification
# JWT_SECRET=

# JWKS endpoint for asymmetric JWT verification (takes precedence over JWT_SECRET)
# JWKS_URL=https://auth.example.com/.well-known/jwks.json

# Comma-separated list of valid API keys for api-key auth mode
# API_KEYS=key1,key2,key3

# ── Routing ──────────────────────────────────────────────────────────

# Default upstream timeout in milliseconds (default: 30000)
DEFAULT_TIMEOUT_MS=30000

# Path to the routes.json configuration file (default: ./routes.json)
# GATEWAY_ROUTES_FILE=routes.json

# ── Optional ─────────────────────────────────────────────────────────

# Enable the /health endpoint (default: true)
HEALTH_CHECK_ENABLED=true
