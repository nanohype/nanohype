# Which provider to activate. Must match a registered provider name.
AUTH_PROVIDER=__AUTH_PROVIDER__

# --- JWT provider (default) ---
# Pick one of the two paths below.
#
# HS256 (shared secret):
# AUTH_JWT_SECRET=replace-me-with-a-long-random-value
#
# RS256/ES256 (JWKS):
# AUTH_JWT_JWKS_URL=https://issuer.example/.well-known/jwks.json

# Optional additional validation:
# AUTH_JWT_ISSUER=https://issuer.example/
# AUTH_JWT_AUDIENCE=__PROJECT_NAME__

# --- Auth0 ---
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_AUDIENCE=__PROJECT_NAME__

# --- Clerk ---
# CLERK_FRONTEND_API=https://clerk.your-app.com
# CLERK_AUDIENCE=__PROJECT_NAME__

# --- Supabase ---
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- API key provider ---
# Comma-separated entries: key[:role1+role2][:label]
# AUTH_API_KEYS=sk_live_abc:admin:billing-bot,sk_live_def:reader:analytics
