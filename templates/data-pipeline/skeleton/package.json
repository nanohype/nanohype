    "@types/node": "^24.12.2",
    "@types/pdf-parse": "^1.1.4",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
