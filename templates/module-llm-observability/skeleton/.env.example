# ── JSON File Exporter ───────────────────────────────────────────────

# Output path for the JSONL file exporter (default: llm-observations.jsonl)
# LLM_OBS_LOG_PATH=llm-observations.jsonl

# ── OTLP Exporter ───────────────────────────────────────────────────
# Requires an OpenTelemetry SDK initialized with an OTLP exporter

# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
