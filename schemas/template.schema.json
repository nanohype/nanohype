{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nanohype.dev/schemas/template.schema.json",
  "title": "nanohype Template",
  "description": "Schema for nanohype template catalog template.yaml files.",
  "type": "object",
  "required": [
    "apiVersion",
    "name",
    "displayName",
    "description",
    "version",
    "tags",
    "variables"
  ],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "nanohype/v1"
    },
    "kind": {
      "type": "string",
      "enum": ["template", "brief"],
      "default": "template",
      "description": "Execution mode. 'template' scaffolds files directly, 'brief' produces agent instruction documents."
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Kebab-case template identifier."
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable template name."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Brief description of the template."
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
      "description": "Semantic version string."
    },
    "license": {
      "type": "string"
    },
    "persona": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "minItems": 1,
      "default": ["engineering"],
      "description": "Who this template serves. Open vocabulary — no enum constraint."
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Catalog grouping (e.g. ai-systems, applications, design, operations)."
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "description": "Lowercase kebab-case tags for discovery."
    },
    "variables": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/variable"
      },
      "description": "Template variables for scaffolding. May be empty."
    },
    "conditionals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conditional"
      }
    },
    "hooks": {
      "$ref": "#/$defs/hooks"
    },
    "composition": {
      "$ref": "#/$defs/composition"
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/prerequisite"
      }
    }
  },
  "$defs": {
    "variable": {
      "type": "object",
      "required": ["name", "type", "placeholder", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9]*$",
          "description": "PascalCase variable name."
        },
        "type": {
          "type": "string",
          "enum": ["string", "bool", "enum", "int"]
        },
        "placeholder": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string"
        },
        "default": {},
        "required": {
          "type": "boolean"
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pattern": {
              "type": "string",
              "description": "Regular expression for value validation."
            },
            "message": {
              "type": "string",
              "description": "Error message shown when validation fails."
            }
          }
        },
        "options": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "if": {
        "properties": {
          "type": { "const": "enum" }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["options"]
      },
      "else": {
        "not": {
          "required": ["options"]
        }
      }
    },
    "conditional": {
      "type": "object",
      "required": ["path", "when"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path to the file governed by this conditional."
        },
        "when": {
          "type": "string",
          "minLength": 1,
          "description": "Variable name that controls inclusion."
        }
      }
    },
    "hookItem": {
      "type": "object",
      "required": ["name", "description", "run"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "run": {
          "type": "string",
          "minLength": 1
        },
        "workdir": {
          "type": "string"
        }
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pre": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hookItem"
          }
        },
        "post": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hookItem"
          }
        }
      }
    },
    "composition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pairsWith": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nestsInside": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "prerequisite": {
      "type": "object",
      "required": ["name", "purpose"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "optional": {
          "type": "boolean"
        }
      }
    }
  }
}
