{
  "config": {
    "default": true,
    // Allow long lines in tables and code blocks
    "MD013": false,
    // Allow duplicate headings in different templates
    "MD024": { "siblings_only": true },
    // Allow trailing punctuation in headings
    "MD026": false,
    // Allow inline HTML (SVG embeds, etc.)
    "MD033": false,
    // Allow bare URLs
    "MD034": false
  },
  "globs": [
    "**/*.md",
    "!node_modules/**",
    "!templates/*/skeleton/**"
  ]
}
