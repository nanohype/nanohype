{
  "name": "@nanohype/sdk",
  "version": "0.1.0",
  "description": "Reference implementation of the nanohype template rendering contract",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "nanohype": "./dist/bin/nanohype.js"
  },
  "files": [
    "dist",
    "schemas",
    "src",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "lint": "tsc --noEmit && eslint 'src/**/*.ts' '__tests__/**/*.ts'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
